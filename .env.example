# Gemini key is optional when GEOTAG_MODE is auto/mock.
GEMINI_API_KEY=

# Keep model configurable due frequent Google model naming changes.
GEMINI_MODEL=gemini-2.0-flash
GEOTAG_MODE=auto
GEOTAG_BATCH_SIZE=40
GEOTAG_TIMEOUT_MS=20000
GEOTAG_MAX_RETRIES=3

# Optional pipeline tuning
MAX_SOURCES=9
MAX_ARTICLES_PER_SOURCE=10
EXTRACTION_ATTEMPT_TIMEOUT_MS=8000
EXTRACTION_TOTAL_TIMEOUT_MS=25000
CURATION_MAX_ARTICLES=40
