# Inception Labs API key is optional when GEOTAG_MODE is auto/mock.
INCEPTION_API_KEY=
INCEPTION_BASE_URL=https://api.inceptionlabs.ai/v1
INCEPTION_MODEL=mercury-2
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
GEOTAG_MODE=auto
GEOTAG_BATCH_SIZE=60
GEOTAG_MAX_API_BATCHES=0
GEOTAG_TIMEOUT_MS=20000
GEOTAG_MAX_RETRIES=4
GEOTAG_RETRY_BASE_DELAY_MS=2000
GEOTAG_RETRY_MAX_DELAY_MS=30000
OUTPUT_ARTICLES_FILE=articles.json
OUTPUT_LAST_UPDATED_FILE=lastUpdated.txt
OUTPUT_FEED_STATE_FILE=feedState.json

# Optional pipeline tuning
MAX_SOURCES=0
MAX_ARTICLES_PER_SOURCE=20
FEED_CONDITIONAL_FETCH=true
EXTRACTION_ATTEMPT_TIMEOUT_MS=8000
EXTRACTION_TOTAL_TIMEOUT_MS=25000
MEDIA_REFRESH_PER_RUN=20
CURATION_MAX_ARTICLES=120
CURATION_MIN_WORD_COUNT=120
ARTICLE_RETENTION_DAYS=21
